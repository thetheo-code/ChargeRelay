DB_NAME=ocpp
DB_USER=ocpp
DB_PASSWORD=change-me

# UI password gate – leave empty to disable (no login screen shown)
UI_PASSWORD=

# Default UI language: "de" (German) or "en" (English)
DEFAULT_LOCALE=de

# SMTP settings for e-mail report delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=ocpp-reports@example.com
